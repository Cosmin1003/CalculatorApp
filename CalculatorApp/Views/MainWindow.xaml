<Window x:Class="CalculatorApp.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CalculatorApp.Views"
        mc:Ignorable="d"
        Title="MainWindow1" Height="600" Width="400">
    <Window.Resources>
        <!-- DataTemplates pentru fiecare tip de ViewModel -->
        <DataTemplate DataType="{x:Type local:StandardMode}">
            <local:StandardMode />
        </DataTemplate>
        <DataTemplate DataType="{x:Type local:ProgrammerMode}">
            <local:ProgrammerMode />
        </DataTemplate>
    </Window.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition/>
        </Grid.RowDefinitions>

        <!-- Butonul permanent -->
        <Button Content="Schimbă Interfața" 
                Command="{Binding SwitchInterfaceCommand}" 
                Margin="10"/>

        <!-- Zona unde se afișează interfața dinamică -->
        <ContentControl Grid.Row="1" 
                        Content="{Binding CurrentViewModel}" 
                        Margin="10"/>
    </Grid>
</Window>
